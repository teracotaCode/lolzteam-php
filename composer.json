{
    "name": "lolzteam/api",
    "description": "PHP API wrapper for Lolzteam Forum and Market",
    "type": "library",
    "license": "MIT",
    "keywords": ["lolzteam", "lolz", "zelenka", "api", "market", "forum"],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lolzteam\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lolzteam\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable"
}
